# Generated Xcode project — regenerate via `xcodegen generate`
Lumo.xcodeproj/

# Developer-local xcconfig — generated by scripts/ios-write-xcconfig.sh
# from ~/.config/lumo/.env. Never commit secrets.
Lumo.local.xcconfig

# Xcode user-state and build artifacts
*.xcuserstate
xcuserdata/
DerivedData/
build/
.build/
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager — xcodegen + xcodebuild manage this; checkout dirs
# can be regenerated. Don't commit Package.resolved either; pinning is in
# project.yml (`packages:` section with explicit `from:` constraints).
.swiftpm/
Package.resolved

# macOS
.DS_Store
