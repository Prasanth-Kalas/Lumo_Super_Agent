// Committed defaults for build-time configuration.
//
// Real values are sourced from `~/.config/lumo/.env` and written into a
// gitignored `Lumo.local.xcconfig` by `scripts/ios-write-xcconfig.sh`.
// The optional include below picks them up when present and silently
// no-ops otherwise, so CI / fresh clones still build.
//
// The Supabase URL is split into scheme + host because xcconfig treats
// `//` as a line comment with no escape — a URL like
// `https://x.supabase.co` would be truncated to `https:`. The Swift
// `AppConfig` reassembles them at runtime.

LUMO_SUPABASE_URL_SCHEME =
LUMO_SUPABASE_URL_HOST =
LUMO_SUPABASE_ANON_KEY =

// ElevenLabs Turbo TTS — populated from ~/.config/lumo/.env. When
// empty the app falls through the TTS chain (ElevenLabs → OpenAI →
// AVSpeechSynthesizer) and surfaces a "configure ElevenLabs" hint
// in Settings rather than crashing.
LUMO_ELEVENLABS_API_KEY =
LUMO_ELEVENLABS_VOICE_ID =

// Stripe — populated from ~/.config/lumo/.env. The publishable key is
// test-mode-only for now (`pk_test_...`); real-money execution waits
// on Phase 4.5 MERCHANT-1. The merchant ID is the Apple Pay merchant
// identifier (e.g. `merchant.com.lumo.rentals.ios`); a placeholder is
// fine while CI signing is off. When the key is empty, Payment Methods
// renders a clean "Payments not configured" state instead of crashing.
LUMO_STRIPE_PUBLISHABLE_KEY_TEST =
LUMO_STRIPE_MERCHANT_ID =

// APNs — populated from ~/.config/lumo/.env. The iOS client only reads
// LUMO_APNS_USE_SANDBOX at runtime (so the Settings UI can show a
// "sandbox APNs" indicator); LUMO_APNS_KEY_ID / LUMO_APNS_TEAM_ID /
// LUMO_APNS_AUTH_KEY_PATH are server-side concerns used by the push
// sender (Phase 4.5+). The aps-environment entitlement is fixed to
// `development` in v1; flip to `production` in Lumo.entitlements when
// app store launch is ready.
LUMO_APNS_USE_SANDBOX = true

#include? "Lumo.local.xcconfig"
