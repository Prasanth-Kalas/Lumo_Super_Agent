<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Lumo</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>0.1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
		</dict>
	</dict>
	<key>LumoAPIBase</key>
	<string>https://lumo-super-agent.vercel.app</string>
	<key>LumoSupabaseURLScheme</key>
	<string>$(LUMO_SUPABASE_URL_SCHEME)</string>
	<key>LumoSupabaseURLHost</key>
	<string>$(LUMO_SUPABASE_URL_HOST)</string>
	<key>LumoSupabaseAnonKey</key>
	<string>$(LUMO_SUPABASE_ANON_KEY)</string>
	<key>LumoStripePublishableKey</key>
	<string>$(LUMO_STRIPE_PUBLISHABLE_KEY_TEST)</string>
	<key>LumoStripeMerchantID</key>
	<string>$(LUMO_STRIPE_MERCHANT_ID)</string>
	<key>LumoAPNsUseSandbox</key>
	<string>$(LUMO_APNS_USE_SANDBOX)</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Lumo uses your microphone so you can talk to your assistant. Your voice is processed on-device for transcription; nothing is recorded or stored.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Lumo uses on-device speech recognition to turn your voice into the messages you send. Transcripts are processed locally; only the resulting text is sent to Lumo.</string>
	<key>NSUserNotificationsUsageDescription</key>
	<string>Lumo notifies you about trip updates, proactive suggestions, and payment receipts. You can customize categories in Settings.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.lumo.rentals.ios.proactive-refresh</string>
	</array>
	<!--
	  AUTH-OAUTH-1b URL schemes:
	  - lumo://auth/callback        — Supabase OAuth callback target.
	                                   ASWebAuthenticationSession matches
	                                   on `lumo` and resumes our session.
	  - com.googleusercontent.apps.971943870024-97g5erdstdg2ue3ho4skr4126e4sovkr
	                                — Google Sign-In reversed-client-ID,
	                                   registered for compatibility with
	                                   the Google identity SDK pattern
	                                   even though we use the Supabase
	                                   web flow rather than the GoogleSignIn
	                                   SDK (kept the bundle clean per brief).
	-->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.lumo.rentals.ios.auth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>lumo</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.lumo.rentals.ios.googleoauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.971943870024-97g5erdstdg2ue3ho4skr4126e4sovkr</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
