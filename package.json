{
  "name": "lumo-super-agent-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Lumo Super Agent monorepo — web (Next.js), iOS (SwiftUI), shared packages, and reference sample agents.",
  "workspaces": [
    "apps/docs",
    "apps/web",
    "packages/*",
    "samples/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/web",
    "docs:build": "npm run build --workspace apps/docs",
    "docs:dev": "npm run dev --workspace apps/docs",
    "docs:api-ref": "npm run docs:api-ref --workspace packages/lumo-agent-sdk",
    "sample:3-leg-trip": "npm run demo --workspace samples/stub-3-leg-trip",
    "start": "npm run start --workspace apps/web",
    "lint": "npm run lint --workspace apps/web",
    "lint:commits": "node scripts/check-commit-shape.mjs",
    "lint:registry": "npm run lint:registry --workspace apps/web",
    "typecheck": "npm run typecheck --workspace apps/web",
    "test": "npm run test --workspace apps/web",
    "eval:phase1": "npm run eval:phase1 --workspace apps/web",
    "clean": "npm run clean --workspace apps/web"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "devDependencies": {
    "webpack": "5.94.0"
  }
}
