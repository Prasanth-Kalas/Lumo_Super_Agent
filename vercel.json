{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "functions": {
    "app/api/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/proactive-scan/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/evaluate-intents/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/proactive-scan",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/evaluate-intents",
      "schedule": "15 8 * * *"
    }
  ]
}
