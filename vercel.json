{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "functions": {
    "app/api/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/proactive-scan/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/evaluate-intents/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/detect-patterns/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/publish-due-posts/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/sync-workspace/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/index-archive/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/proactive-scan",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/evaluate-intents",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/detect-patterns",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/publish-due-posts",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/sync-workspace",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/index-archive",
      "schedule": "*/30 * * * *"
    }
  ]
}
