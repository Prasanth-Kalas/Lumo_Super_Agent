# Anthropic — used for the Claude tool-use loop.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# OpenAI — failover model for when Anthropic is unhealthy. Optional in dev.
OPENAI_API_KEY=

# Path to the registry config. Defaults to config/agents.registry.json.
# Point at config/agents.registry.prod.json for the old hardcoded prod overlay,
# or config/agents.registry.vercel.json for the env-driven Vercel overlay.
LUMO_REGISTRY_PATH=

# Public base URL of this shell. Used only for link generation; the agents
# do not call back to the shell.
LUMO_SHELL_PUBLIC_URL=http://localhost:3000

# ─── Cross-agent wiring (used by config/agents.registry.vercel.json) ────────
# The Vercel overlay leaves these as ${VAR} placeholders in JSON and relies on
# lib/agent-registry.ts → expandEnvRefs() to substitute them at boot. In local
# dev the default registry JSON uses http://localhost:3001 / :3002 directly,
# so you can leave these unset unless you're testing the Vercel overlay path.

# Food agent base URL (where the Super Agent dispatches food tool calls).
#   Dev:     http://localhost:3001
#   Vercel:  https://<your-food-project>.vercel.app
#            https://food.agents.lumo.rentals
LUMO_FOOD_AGENT_URL=

# Flight agent base URL.
#   Dev:     http://localhost:3002
#   Vercel:  https://<your-flight-project>.vercel.app
#            https://flight.agents.lumo.rentals
LUMO_FLIGHT_AGENT_URL=

# ─── Supabase (persistence + auth) ──────────────────────────────────────────
# Service-role is server-only. Never commit, never expose to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public Supabase keys — the anon key IS meant to be public and is bundled
# into the browser build. The NEXT_PUBLIC_ prefix makes Next.js expose it.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Appstore: OAuth token encryption at rest ───────────────────────────────
# 32-byte key, hex-encoded (64 chars). Generate with:
#   openssl rand -hex 32
# Every per-user agent access/refresh token in the agent_connections table
# is sealed with AES-256-GCM under this key. Rotating the key invalidates
# every stored connection (acceptable as a privileged ops action in MVP).
LUMO_ENCRYPTION_KEY=

# OAuth client credentials the Super Agent presents to each downstream
# agent at the /oauth/token endpoint. One pair per connected agent.
# In MVP we ship only Food; prod adds one LUMO_<AGENT>_CLIENT_{ID,SECRET}
# pair per registered agent. An agent can also accept a public client
# (no secret) — the dispatcher sends only the id in that case.
LUMO_FOOD_OAUTH_CLIENT_ID=lumo-super-agent
LUMO_FOOD_OAUTH_CLIENT_SECRET=

# ─── Observability ─────────────────────────────────────────────────────────
# Comma-separated emails that are allowed to view /ops and call
# /api/ops/summary. Empty = no admins (closed by default). Matching is
# case-insensitive. Example:
#   LUMO_ADMIN_EMAILS=prasanth.kalas@lumo.rentals,ops@lumo.rentals
LUMO_ADMIN_EMAILS=

# ─── Personal integrations: Google (Gmail + Calendar + Contacts) ──────────
# Create a Google Cloud project → APIs & Services → OAuth consent screen
# (External, Testing at first), then Credentials → OAuth 2.0 Client IDs →
# Web application. Authorized redirect URI:
#   https://<your-deployment>/api/connections/callback
# (and http://localhost:3000/api/connections/callback for local dev).
# Enable the APIs: Gmail API, Google Calendar API, People API.
# See docs/integrations-google.md for the full walkthrough.
LUMO_GOOGLE_CLIENT_ID=
LUMO_GOOGLE_CLIENT_SECRET=
